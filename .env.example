# API tokens
APIFY_API_TOKEN=
APIFY_TIKTOK_ACTOR_ID=clockworks/tiktok-scraper
APIFY_RESULTS_LIMIT=40
# Optional: saved Apify dataset export for offline/demo mode
APIFY_TIKTOK_ITEMS_JSON=
# Optional: override generic actor input
APIFY_TIKTOK_ACTOR_INPUT_JSON=
LLM_PROVIDER=nemotron
# NVIDIA/Nemotron OpenAI-compatible endpoint. NEMOTRON_API_KEY is preferred;
# NVIDIA_API_KEY or LLM_API_KEY also work.
NEMOTRON_API_KEY=
NVIDIA_API_KEY=
LLM_API_KEY=
NEMOTRON_MODEL=mistralai/mistral-nemotron
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Google OAuth / outputs
GOOGLE_OAUTH_CLIENT_SECRET_JSON=./secrets/google-oauth-client.json
GOOGLE_TOKEN_JSON=./secrets/google-token.json
# Simpler dev/demo auth: paste an OAuth access token with Drive + Sheets scopes
GOOGLE_ACCESS_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEET_ID=

# Optional source helpers
YOUTUBE_COOKIES_FILE=
TRENDCUT_YOUTUBE_URLS_FILE=

# Local paths
TRENDCUT_LOCAL_INBOX=./samples/inbox
TRENDCUT_AUDIO_LIBRARY=./samples/audio
TRENDCUT_OUTPUT_DIR=./output
